<AnchorPane prefHeight="480.0" prefWidth="701.0" style="-fx-background-color: #EADDCA;" xmlns="http://javafx.com/javafx/19" xmlns:fx="http://javafx.com/fxml/1" fx:controller="edu.sdccd.cisc191.template.Sample1">
