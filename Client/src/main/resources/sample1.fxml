            <Label layoutX="10.0" layoutY="69.0" text="Input Menu Quantity" />
            <TextField fx:id="menuQuantity" layoutX="10.0" layoutY="86.0" />
            <Button fx:id="submit" mnemonicParsing="false" onAction="#submit" prefHeight="76.0" prefWidth="149.0" text="Add Data" />
         </children>
      </VBox>
      <Button layoutX="499.0" layoutY="348.0" mnemonicParsing="false" onMouseClicked="#remove" text="Remove" />
