                     <font>
                        <Font size="32.0" />
                     </font>
                  </Label>
               </children>
            </Pane>
            <Button fx:id="button" mnemonicParsing="false" onMouseClicked="#addData" prefHeight="70.0" prefWidth="193.0" style="-fx-background-color: #C19A6B;" text="Add data" />
            <Button fx:id="DisplayMenu" layoutX="10.0" layoutY="10.0" mnemonicParsing="false" onMouseClicked="#displayMenuScene" prefHeight="70.0" prefWidth="193.0" style="-fx-background-color: #C19A6B;" text="Display Menu" />
            <Button layoutX="10.0" layoutY="80.0" mnemonicParsing="false" prefHeight="70.0" prefWidth="193.0" style="-fx-background-color: #C19A6B;" text="Types of items" />
